{
  "name": "gtmcanon",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": ".next",

  // KV namespace for query analytics
  // Create with: bunx wrangler kv namespace create ANALYTICS
  // Then paste the id below
  "kv_namespaces": [
    {
      "binding": "ANALYTICS",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],

  // Environment variables
  // Set via: bunx wrangler pages secret put ADMIN_STATS_TOKEN
  "vars": {}
}
